# Copy to .env and set a long random secret:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Password reset emails (https://resend.com -> API Keys -> Create)
RESEND_API_KEY=re_xxxxxxxx
# Sender - any address on the verified domain works
MAIL_FROM="ISC Hour Tracker <no-reply@fnaf.sy-baubau.ch>"
# Public URL of the app, used to build reset links in the email
APP_URL=http://localhost:3000
